#
# Check that groups and an environment can both be installed.

%ksappend repos/default.ks
%ksappend common/common_no_payload.ks

%packages
%ksappend payload/environment1.ks
@dns-server
%end


%post

@KSINCLUDE@ scripts-lib.sh
platform="$(get_platform @KSTEST_OS_NAME@ @KSTEST_OS_VERSION@)"

# We don't have a way of determining if a group/env is installed or not.
# These sentinel packages (mandatory in mandatory group) will have to do.
if [ "${platform:0:4}" == "rhel" ] || [ "${platform:0:6}" == "centos" ] || [ "${platform}" == "fedora-eln" ]; then
    SENTINEL_PACKAGE=qemu-kvm
else
    SENTINEL_PACKAGE=fedora-release-cloud
fi

rpm -q ${SENTINEL_PACKAGE}
if [[ $? != 0 ]]; then
    echo "*** package ${SENTINEL_PACKAGE} mandatory for the environment was not installed" >> /root/RESULT
fi

# bind-chroot is mandatory in dns-server group
rpm -q bind-chroot
if [[ $? != 0 ]]; then
    echo "*** dns-server group was not installed" >> /root/RESULT
fi

%ksappend validation/success_if_result_empty.ks
%end
